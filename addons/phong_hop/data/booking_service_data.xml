<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- Danh mục dịch vụ đi kèm mặc định (Đề 6 - Giai đoạn 2) -->
    <record id="service_tra" model="booking_service">
      <field name="name">Trà</field>
      <field name="mo_ta">Phục vụ trà nóng</field>
      <field name="gia">15000</field>
      <field name="sequence">10</field>
    </record>

    <record id="service_cafe" model="booking_service">
      <field name="name">Cà phê</field>
      <field name="mo_ta">Cà phê pha sẵn</field>
      <field name="gia">25000</field>
      <field name="sequence">20</field>
    </record>

    <record id="service_nuoc_suoi" model="booking_service">
      <field name="name">Nước suối</field>
      <field name="mo_ta">Nước đóng chai</field>
      <field name="gia">10000</field>
      <field name="sequence">30</field>
    </record>

    <record id="service_banh_ngot" model="booking_service">
      <field name="name">Bánh ngọt</field>
      <field name="mo_ta">Đĩa bánh ngọt tráng miệng</field>
      <field name="gia">50000</field>
      <field name="sequence">40</field>
    </record>

    <record id="service_hoa_trang_tri" model="booking_service">
      <field name="name">Hoa trang trí</field>
      <field name="mo_ta">Trang trí bàn họp</field>
      <field name="gia">200000</field>
      <field name="sequence">50</field>
    </record>

    <record id="service_nguoi_phuc_vu" model="booking_service">
      <field name="name">Người phục vụ</field>
      <field name="mo_ta">Nhân viên phục vụ trong cuộc họp</field>
      <field name="gia">300000</field>
      <field name="sequence">60</field>
    </record>

  </data>
</odoo>
