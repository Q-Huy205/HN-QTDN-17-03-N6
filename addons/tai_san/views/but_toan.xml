<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Tree gọn cho bút toán tài sản (account.move lọc theo sổ nhật ký TS) -->
    <record id="view_but_toan_tai_san_tree" model="ir.ui.view">
      <field name="name">tai_san.but_toan.tree</field>
      <field name="model">account.move</field>
      <field name="arch" type="xml">
        <tree string="Bút toán tài sản" create="false" edit="false"
              decoration-info="state == 'draft'"
              decoration-success="state == 'posted'">
          <field name="name"/>
          <field name="ref" string="Tham chiếu"/>
          <field name="date" string="Ngày"/>
          <field name="journal_id" string="Sổ nhật ký"/>
          <field name="amount_total" string="Số tiền" sum="Tổng"/>
          <field name="state" string="Trạng thái"/>
        </tree>
      </field>
    </record>

    <!-- Form gọn: hiện thẳng các dòng Nợ/Có, không phụ thuộc nhóm kế toán -->
    <record id="view_but_toan_tai_san_form" model="ir.ui.view">
      <field name="name">tai_san.but_toan.form</field>
      <field name="model">account.move</field>
      <field name="arch" type="xml">
        <form string="Bút toán tài sản" create="false">
          <header>
            <button name="action_post" type="object" string="Ghi sổ" class="btn-primary"
                    attrs="{'invisible': [('state', '!=', 'draft')]}"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1><field name="name" readonly="1"/></h1>
            </div>
            <group>
              <group>
                <field name="ref" string="Tham chiếu" readonly="1"/>
                <field name="date" string="Ngày hạch toán" readonly="1"/>
              </group>
              <group>
                <field name="journal_id" string="Sổ nhật ký" readonly="1"/>
                <field name="amount_total" string="Tổng tiền" readonly="1"/>
              </group>
            </group>
            <notebook>
              <page string="Định khoản (Nợ / Có)">
                <field name="line_ids" readonly="1">
                  <tree>
                    <field name="account_id" string="Tài khoản"/>
                    <field name="name" string="Diễn giải"/>
                    <field name="debit" string="Nợ" sum="Tổng Nợ"/>
                    <field name="credit" string="Có" sum="Tổng Có"/>
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Action: chỉ hiện bút toán thuộc sổ nhật ký "Bút toán tài sản" (code TS) -->
    <record id="action_but_toan_tai_san" model="ir.actions.act_window">
      <field name="name">Bút toán tài sản</field>
      <field name="res_model">account.move</field>
      <field name="view_mode">tree,form</field>
      <field name="domain">[('journal_id.code', '=', 'TS')]</field>
      <field name="view_ids" eval="[(5, 0, 0),
          (0, 0, {'sequence': 1, 'view_mode': 'tree', 'view_id': ref('view_but_toan_tai_san_tree')}),
          (0, 0, {'sequence': 2, 'view_mode': 'form', 'view_id': ref('view_but_toan_tai_san_form')})]"/>
      <field name="context">{'create': False}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">Chưa có bút toán tài sản nào.</p>
        <p>Bút toán được sinh ra khi bạn bấm nút <b>"Tạo bút toán"</b> ở phiếu Khấu hao hoặc Thanh lý.</p>
      </field>
    </record>

  </data>
</odoo>
